<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- RepForge design system: dark steel surfaces, ember accent, soft corners. -->

    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    </Style>

    <!-- Rounded controls everywhere -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="NumericUpDown">
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="CheckBox">
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!-- Lists sit directly on the app background; rows get soft hit areas -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <!-- Compact tab headers (Fluent's default is oversized pivot text);
         sized so all six fit across a phone-width bottom bar -->
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="MinHeight" Value="44" />
    </Style>

    <!-- Card surface used for exercise/session blocks -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="BoxShadow" Value="0 2 10 0 #33000000" />
    </Style>

    <!-- Typography helpers -->
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.dim">
        <Setter Property="Opacity" Value="0.6" />
    </Style>
</Styles>
