<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RepForge.ViewModels"
             xmlns:sys="using:System"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="RepForge.Views.SessionDetailView"
             x:DataType="vm:SessionDetailViewModel">

  <DockPanel Margin="12">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
      <Button Grid.Column="0" Content="← Back" Margin="0,0,8,0"
              Command="{Binding CloseCommand}" />
      <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
        <TextBlock Text="{Binding DateText}" FontSize="12" Opacity="0.6"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Grid>

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:HistoryExerciseGroup">
            <Border BorderBrush="#40808080" BorderThickness="1" CornerRadius="8"
                    Padding="10" Margin="0,0,0,10">
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding Sets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="sys:String">
                      <TextBlock Text="{Binding}" FontSize="13" Margin="0,1" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
