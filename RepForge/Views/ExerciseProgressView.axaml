<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RepForge.ViewModels"
             xmlns:controls="using:RepForge.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="RepForge.Views.ExerciseProgressView"
             x:DataType="vm:ExerciseProgressViewModel">

  <DockPanel Margin="12">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
      <Button Grid.Column="0" Content="← Back" Margin="0,0,8,0"
              Command="{Binding CloseCommand}" />
      <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Subtitle}" Classes="dim" FontSize="12" />
      </StackPanel>
    </Grid>

    <StackPanel Spacing="10">
      <Border Classes="card">
        <controls:TrendChart Height="220" Points="{Binding Points}" />
      </Border>
      <TextBlock Text="{Binding BestText}" FontWeight="SemiBold" TextWrapping="Wrap" />
    </StackPanel>
  </DockPanel>
</UserControl>
