<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RepForge.ViewModels"
             xmlns:m="using:RepForge.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="RepForge.Views.TemplateEditorView"
             x:DataType="vm:TemplateEditorViewModel">

  <DockPanel Margin="12">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
      <Button Grid.Column="0" Content="← Back" Margin="0,0,8,0"
              Command="{Binding CloseCommand}" />
      <TextBox Grid.Column="1" Text="{Binding Name}" Watermark="Workout name"
               FontWeight="SemiBold" />
    </Grid>

    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <ComboBox Grid.Column="0" Margin="0,0,8,0" HorizontalAlignment="Stretch"
                ItemsSource="{Binding Library}"
                SelectedItem="{Binding SelectedExercise}"
                PlaceholderText="Choose an exercise…">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="m:Exercise">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding Name}" />
              <TextBlock Text="{Binding MuscleGroup}" Opacity="0.6" />
            </StackPanel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Grid.Column="1" Content="Add" Command="{Binding AddExerciseCommand}" />
    </Grid>

    <ListBox ItemsSource="{Binding Items}">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:TemplateExerciseItem">
          <StackPanel Spacing="6" Margin="0,4">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
              <TextBlock Grid.Column="0" Text="{Binding ExerciseName}"
                         FontWeight="SemiBold" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="↑" Background="Transparent"
                      Command="{Binding $parent[ListBox].((vm:TemplateEditorViewModel)DataContext).MoveUpCommand}"
                      CommandParameter="{Binding}" />
              <Button Grid.Column="2" Content="↓" Background="Transparent"
                      Command="{Binding $parent[ListBox].((vm:TemplateEditorViewModel)DataContext).MoveDownCommand}"
                      CommandParameter="{Binding}" />
              <Button Grid.Column="3" Content="✕" Background="Transparent"
                      Command="{Binding $parent[ListBox].((vm:TemplateEditorViewModel)DataContext).RemoveItemCommand}"
                      CommandParameter="{Binding}" />
            </Grid>
            <WrapPanel ItemSpacing="8" LineSpacing="4">
              <StackPanel Spacing="2">
                <TextBlock Text="Sets" FontSize="11" Opacity="0.6" />
                <NumericUpDown Value="{Binding Sets}" Minimum="1" Maximum="20"
                               FormatString="0" Width="110" />
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="Reps" FontSize="11" Opacity="0.6" />
                <NumericUpDown Value="{Binding Reps}" Minimum="1" Maximum="100"
                               FormatString="0" Width="110" />
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="Weight" FontSize="11" Opacity="0.6" />
                <NumericUpDown Value="{Binding Weight}" Minimum="0" Maximum="2000"
                               Increment="5" Watermark="—" Width="120" />
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="Rest (s)" FontSize="11" Opacity="0.6" />
                <NumericUpDown Value="{Binding RestSeconds}" Minimum="0" Maximum="600"
                               Increment="15" FormatString="0" Width="110" />
              </StackPanel>
            </WrapPanel>
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
