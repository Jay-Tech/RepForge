<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RepForge.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="RepForge.Views.ActiveSessionView"
             x:DataType="vm:ActiveSessionViewModel">

  <DockPanel Margin="12">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
      <StackPanel Grid.Column="0" Spacing="2">
        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Text="{Binding StartedText}" FontSize="12" Opacity="0.6" />
      </StackPanel>
      <Button Grid.Column="1" Content="Discard" Opacity="0.7" Margin="0,0,8,0"
              VerticalAlignment="Center"
              Command="{Binding DiscardCommand}" />
      <Button Grid.Column="2" Content="Finish" Classes="accent"
              VerticalAlignment="Center"
              Command="{Binding FinishCommand}" />
    </Grid>

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Exercises}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SessionExerciseViewModel">
            <Border Classes="card" Margin="0,0,0,10">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding ExerciseName}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TargetSummary}" FontSize="12" Opacity="0.6"
                               IsVisible="{Binding TargetSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Text="{Binding LastTime}" FontSize="12" Opacity="0.6"
                               IsVisible="{Binding LastTime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding Progress}" FontSize="12"
                             Opacity="0.6" VerticalAlignment="Top" />
                </Grid>

                <ItemsControl ItemsSource="{Binding Sets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:LoggedSetViewModel">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Display}"
                                   VerticalAlignment="Center" FontSize="13" />
                        <Button Grid.Column="1" Content="✕" FontSize="11"
                                Background="Transparent" Padding="6,2"
                                Command="{Binding $parent[ItemsControl].((vm:SessionExerciseViewModel)DataContext).DeleteSetCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid ColumnDefinitions="*,*,Auto" IsVisible="{Binding IsStrength}">
                  <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                    <TextBlock Text="Reps" FontSize="11" Opacity="0.6" />
                    <NumericUpDown Value="{Binding Reps}" Minimum="0" Maximum="100"
                                   FormatString="0" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2" Margin="0,0,8,0">
                    <TextBlock Text="Weight" FontSize="11" Opacity="0.6" />
                    <NumericUpDown Value="{Binding Weight}" Minimum="0" Maximum="2000"
                                   Increment="5" Watermark="—" />
                  </StackPanel>
                  <Button Grid.Column="2" Content="Log set" VerticalAlignment="Bottom"
                          Command="{Binding LogSetCommand}" />
                </Grid>
                <StackPanel Spacing="8" IsVisible="{Binding IsCardio}">
                  <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                      <TextBlock Text="Distance" FontSize="11" Opacity="0.6" />
                      <NumericUpDown Value="{Binding Distance}" Minimum="0" Maximum="1000"
                                     Increment="0.5" Watermark="—" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="Time (min)" FontSize="11" Opacity="0.6" />
                      <NumericUpDown Value="{Binding Minutes}" Minimum="0" Maximum="600"
                                     Increment="1" Watermark="—" />
                    </StackPanel>
                  </Grid>
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                      <TextBlock Text="Laps" FontSize="11" Opacity="0.6"
                                 VerticalAlignment="Center" />
                      <Button Content="−" Padding="12,4"
                              Command="{Binding RemoveLapCommand}" />
                      <TextBlock Text="{Binding Laps}" FontWeight="SemiBold" FontSize="16"
                                 MinWidth="24" TextAlignment="Center"
                                 VerticalAlignment="Center" />
                      <Button Content="+" Padding="12,4"
                              Command="{Binding AddLapCommand}" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="Log" VerticalAlignment="Center"
                            Command="{Binding LogSetCommand}" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
